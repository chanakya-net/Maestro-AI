    "provider_routing_rules": {
      "google": {
        "automatic_routing": "all",
        "preferred_agents": [
          "agy"
        ],
        "fallback_agents": [
          "agy"
        ],
        "_note": "Google/Gemini models may be used for any complexity band, but must be executed via AGY only. Gemini models are not eligible on GitHub Copilot."
      },
      "anthropic": {
        "automatic_routing": "all",
        "preferred_agents": [
          "github-copilot",
          "claude"
        ],
        "fallback_agents": [
          "claude"
        ],
        "_note": "Anthropic models route through any available agent (github-copilot or direct claude). claude-opus-4-7 and claude-opus-4.7 are min_band=holy-fuck and should not appear below that band."
      }
    },
    "hard_minimum_overrides": [
      "dependency state unknown or conflicting → weight_min=9",
      "heavy shared-file ownership conflict → weight_min=9",
      "broad cross-module integration change → weight_min=7",
      "explicit user request for deep/complex → weight_min=9"
    ],
    "band_required_models": {
      "complex": [
        "gpt-5.5"
      ],
      "holy-fuck": [
        "gpt-5.5",
        "claude-opus-4.7",
        "claude-opus-4-7"
      ],
      "_note": "These models are pinned into the pool regardless of subscription-neutral ranking. Ensures frontier options (GPT + Claude Opus) are always available at high complexity. Claude Opus is pinned only at holy-fuck; min_band=holy-fuck on catalog entries prevents it from routing into lower bands."
    },
    "interchangeable_agent_groups": [
      {
        "agents": [
          "codex",
          "github-copilot"
        ],
        "selection": "random",
        "_note": "Both run GPT models identically. Pick randomly between whichever are detected and not filtered."
      }
    ],
    "agent_preference_rules": [
      {
        "models": [
          "claude-opus-4.7",
          "claude-opus-4-7"
        ],
        "preferred_agents": [
          "claude",
          "github-copilot"
        ],
        "_note": "When Opus 4.7 is selected, prefer direct Claude agent first, then fall back to GitHub Copilot. Direct Claude runs the native Anthropic model without any intermediary."
      },
      {
        "models": [
          "claude-haiku-4.5",
          "claude-haiku-4-5"
        ],
        "preferred_agents": [
          "github-copilot",
          "claude"
        ],
        "_note": "If Haiku 4.5 is selected and both GitHub Copilot and Claude are available, choose GitHub Copilot before direct Claude. claude-haiku-4.5 = Copilot CLI ID; claude-haiku-4-5-20251001 = Claude CLI ID."
      },
      {
        "provider": "anthropic",
        "direct_agent": "claude",
        "automatic_routing": "all",
        "preferred_agents": [
          "github-copilot",
          "claude"
        ],
        "_note": "Direct Claude agent is an equal peer in automatic routing. claude-opus-4-7/4.7 are min_band=holy-fuck and excluded from lower bands automatically."
      }
    ]
