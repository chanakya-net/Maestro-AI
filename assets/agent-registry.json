  "model_routing": {
    "score_to_weight": [
      {"score_min":  8, "score_max": 12, "weight_min": 1, "weight_max": 3, "label": "quite-easy"},
      {"score_min": 13, "score_max": 17, "weight_min": 2, "weight_max": 4, "label": "easy"},
      {"score_min": 18, "score_max": 22, "weight_min": 4, "weight_max": 6, "label": "medium"},
      {"score_min": 23, "score_max": 27, "weight_min": 6, "weight_max": 7, "label": "medium-hard"},
      {"score_min": 28, "score_max": 32, "weight_min": 7, "weight_max": 9, "label": "complex"},
      {"score_min": 33, "score_max": 40, "weight_min": 9, "weight_max": 10, "label": "holy-fuck"}
    ],
    "selection_strategy": "top-n-cheapest-random",
    "selection_pool_size": 4,
    "cost_basis": "agent-subscription-routing-units",
    "_strategy_note": "Sort candidates by (complexity_weight ASC, price_tier ASC, price_output_per_1m ASC). For Copilot models, price_* fields represent subscription multipliers from the user's available model list, not API dollars. Agent-specific routing_cost_overrides take precedence when routing is constrained to that agent; Codex and Claude models are subscription-included because those agents do not expose per-model multipliers. Take the top selection_pool_size models, then randomly pick one from that pool.",
    "provider_routing_rules": {
      "google": {
        "max_band": "easy",
        "automatic_routing": "easy_only",
        "_note": "Google/Gemini models may enter the normal automatic pool only for quite-easy and easy tasks. Do not use Gemini as a last-resort fallback for medium or harder work unless explicitly selected by AGENT/MODEL overrides."
      },
      "anthropic": {
        "automatic_routing": "fallback_only_for_direct_claude",
        "preferred_agents": ["github-copilot"],
        "fallback_agents": ["claude"],
        "_note": "Claude-provider models should use GitHub Copilot first when both Copilot and direct Claude support the model. Direct Claude is reserved for cases where other agents/models cannot perform the task or are filtered/unavailable."
      }
    },
    "hard_minimum_overrides": [
      "dependency state unknown or conflicting → weight_min=9",
      "heavy shared-file ownership conflict → weight_min=9",
      "broad cross-module integration change → weight_min=7",
      "explicit user request for deep/complex → weight_min=9"
    ],
    "band_required_models": {
      "complex":    ["gpt-5.5"],
      "holy-fuck":  ["gpt-5.5"],
      "_note": "These models are pinned into the pool regardless of price ranking. Ensures frontier GPT options are always available at high complexity even when cheaper models dominate the cost-sorted slots."
    },
    "interchangeable_agent_groups": [
      {
        "agents": ["codex", "github-copilot"],
        "selection": "random",
        "_note": "Both run GPT models identically. Pick randomly between whichever are detected and not filtered."
      }
    ],
    "agent_preference_rules": [
      {
        "models": ["claude-haiku-4.5", "claude-haiku-4-5-20251001", "claude-haiku-4-5"],
        "preferred_agents": ["github-copilot", "claude"],
        "_note": "If Haiku 4.5 is selected and both GitHub Copilot and Claude are available, choose GitHub Copilot before direct Claude. claude-haiku-4.5 = Copilot CLI ID; claude-haiku-4-5-20251001 = Claude CLI ID."
      },
      {
        "provider": "anthropic",
        "direct_agent": "claude",
        "automatic_routing": "fallback_only",
        "preferred_agents": ["github-copilot"],
        "_note": "Use direct Claude only after non-Claude agents/models are unavailable, filtered out, or judged unable to perform the task."
      }
    ]
  },
